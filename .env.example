# ===== 楽天 API =====
# 楽天Developersで取得したアプリID
RAKUTEN_APP_ID=your_rakuten_app_id_here

# ===== Google Gemini API =====
# Google AI Studioで取得したAPIキー (Free Tier)
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Groq API (アフィリ送客システムのLLM) =====
# https://console.groq.com で取得。指揮官＋各エージェントが使用。
GROQ_API_KEY=your_groq_api_key_here
# 使用モデル（任意。デフォルト llama-3.3-70b-versatile）
AFFILIATE_LLM_MODEL=llama-3.3-70b-versatile

# ===== 誘導先(CTA)設定 =====
# 基本は affiliate.config.json（GitHubアプリで直接編集可）。env があれば優先。
# type: line（LINE登録を軸/推奨） | blog（ブログ記事） | consult（無料面談に直）
AFFILIATE_FUNNEL_TYPE=
AFFILIATE_LINE_URL=
AFFILIATE_BLOG_URL=
AFFILIATE_LEAD_MAGNET=
AFFILIATE_BRAND=

# ===== X高単価アフィリ送客システム =====
# 【方式1・推奨/鍵不要】Apps Script Webアプリ方式（スマホで設定可・組織ポリシー回避）
# tools/affiliate-sheets-webapp.gs をスプレッドシートに貼り、ウェブアプリとしてデプロイ
AFFILIATE_SHEETS_WEBAPP_URL=
AFFILIATE_SHEETS_TOKEN=
#
# 【方式2】サービスアカウント方式（鍵が作れる環境向け）
# 出力先 Googleスプレッドシートの ID（URLの /d/ と /edit の間の文字列）
AFFILIATE_SHEET_ID=your_google_spreadsheet_id_here
# サービスアカウントの認証情報。次のどちらかを設定:
#  (A) JSON文字列をそのまま（GitHub Secrets向け）
GOOGLE_SERVICE_ACCOUNT_JSON=
#  (B) JSONファイルへのパス（ローカル向け）
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# Web UI のポート（任意。デフォルト 3100）
AFFILIATE_PORT=3100
# CLI/Actions 用のデフォルト案件名（任意）
AFFILIATE_OFFER=

# ===== X (旧Twitter) API =====
# X Developer Portal (https://developer.twitter.com) でアプリを作成し取得
# OAuth 1.0a の「Read and Write」権限が必要
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
# X(Twitter)のユーザー名（@なし）: CTAのフォロー誘導文に使用
X_USERNAME=your_x_username_here

# ===== 通知設定 (Discord Webhook) =====
# DiscordサーバーのWebhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ===== 楽天ROOM セッションCookie =====
# tools/cookie-exporter.ts で取得したJSON形式のCookie配列
# 例: [{"name":"session","value":"...","domain":".room.rakuten.co.jp",...}]
ROOM_COOKIE=[]

# ===== 商品取得設定 =====
# ターゲットジャンル: "general" | "furusato" | "electronics" | "1000yen"
TARGET_GENRE=general

# 1回の実行で投稿する商品数 (デフォルト: 3)
POST_COUNT=3

# 価格下限・上限 (円)
MIN_PRICE=1000
MAX_PRICE=5000

# ===== ジャンルID設定 (楽天ジャンルID) =====
# 総合ランキング用ジャンルID (空白=全体)
GENRE_ID_GENERAL=
# ふるさと納税ジャンルID
GENRE_ID_FURUSATO=553066
# 季節家電ジャンルID
GENRE_ID_ELECTRONICS=215783
